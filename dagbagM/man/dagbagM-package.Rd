\name{dagbagM-package}
\alias{dagbagM-package}
\alias{dagbagM}
\docType{package}
\title{DAG bagging for mixed node types}
\description{
Local package for learning directed acyclic graphs from mixtures of continuous
and binary variables using hill climbing and bootstrap aggregation.
}
\details{
The v2 implementation uses operation-specific hill-climbing caches, stricter
input validation, finite-score guards, native C++ adjacency lists, and
frequency-based bootstrap aggregation.
}
\keyword{package}

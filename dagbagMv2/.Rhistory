setwd("~/Documents/GitHub/dagbagM/dagbagMv2")
devtools::install()
library(dagbagMv2)
data(example)
Y.n      <- example$Y
p        <- ncol(Y.n)
true.dir <- example$true.dir
true.ske <- skeleton(true.dir)
nodeType <- rep("c", p)
N_BOOT   <- 200   # adjust as needed
SEED     <- 1
N_THREAD <- 5    # adjust to available cores
## ── hc_boot_parallel (original: full-data std, old seeding) ─────────────────
t1 <- proc.time()
freq.par <- hc_boot_parallel(
Y = Y.n, n.boot = N_BOOT, nodeType = nodeType,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = SEED, nodeShuffle = TRUE,
numThread = N_THREAD, output_type = "freq"
)
t1 <- (proc.time() - t1)[3]
## ── hc_boot current (per-sample std, upfront seeding) ───────────────────────
t2 <- proc.time()
freq.new <- hc_boot(
Y = Y.n, n.boot = N_BOOT, nodeType = nodeType,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = SEED, nodeShuffle = TRUE,
backend = "future", workers=N_THREAD,  output_type = "freq"
)
t2 <- (proc.time() - t2)[3]
cat(sprintf("hc_boot_parallel : %.1fs\n", t1))
cat(sprintf("hc_boot          : %.1fs\n\n", t2))
## ── Frequency matrix comparison ──────────────────────────────────────────────
diff <- freq.new - freq.par
ut   <- upper.tri(diff)    # off-diagonal upper triangle (p*(p-1)/2 pairs)
cat("=== Frequency matrix (upper triangle, off-diagonal) ===\n")
cat(sprintf("  max |diff|  : %.6f\n", max(abs(diff[ut]))))
cat(sprintf("  mean |diff| : %.6f\n", mean(abs(diff[ut]))))
cat(sprintf("  correlation : %.6f\n", cor(freq.new[ut], freq.par[ut])))
## ── Aggregated DAG comparison ────────────────────────────────────────────────
eval_dag <- function(adj) {
fdr   <- if (sum(adj) > 0) sum(adj == 1 & true.dir == 0) / sum(adj) else NA
power <- sum(adj == 1 & true.dir == 1) / sum(true.dir)
ske   <- skeleton(adj)
s_fdr   <- if (sum(ske) > 0) sum(ske == 1 & true.ske == 0) / sum(ske) else NA
s_power <- sum(ske == 1 & true.ske == 1) / sum(true.ske)
c(DAG_FDR = fdr, DAG_Power = power, SKE_FDR = s_fdr, SKE_Power = s_power)
}
adj.par <- score_shd_freq(freq.par, alpha = 1, freq.cutoff = 0.5)
adj.new <- score_shd_freq(freq.new, alpha = 1, freq.cutoff = 0.5)
res <- rbind(
"hc_boot_parallel" = eval_dag(adj.par),
"hc_boot"          = eval_dag(adj.new)
)
cat("\n=== Aggregated DAG (freq.cutoff = 0.5) ===\n")
print(round(res, 7))
cat(sprintf("\nEdge counts: hc_boot_parallel=%d  hc_boot=%d\n",
sum(adj.par), sum(adj.new)))
cat(sprintf("Edges in common: %d\n", sum(adj.par == 1 & adj.new == 1)))

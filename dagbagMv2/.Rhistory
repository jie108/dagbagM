## v1
rm(list=ls())
library(dagbagM)
data(example)
Y.n=example$Y # data matrix
p<- dim(Y.n)[2] # no. of nodes: p=102
n<-dim(Y.n)[1] # sample size: n=102
true.dir=example$true.dir  # adjacency matrix of the data generating DAG
true.moral=moral_graph(true.dir) ## moral graph of the data generating DAG
true.ske=skeleton(true.dir)  # skeleton graph of the data generating DAG
true.vstr=vstructures(true.dir) ## vstructures of the data generating DAG
sum(true.dir) #number of edges: |E|= 109
#(i)
temp<- dagbagM::hc(Y=Y.n,nodeType=rep("c",p), whiteList=NULL, blackList=NULL, tol = 1e-6, standardize=TRUE, maxStep = 1000, restart=1, seed = 1,  verbose = FALSE)
adj.temp=temp$adjacency
# Evaluations
# results on DAG estimation
sum(adj.temp==1&true.dir==0)/sum(adj.temp==1) ## FDR: 0.8803681
sum(adj.temp==1&true.dir==1)/sum(true.dir==1) ## Power: 0.3577982
# results on skeleton graph estimation
adj.temp.ske=skeleton(adj.temp)
sum(adj.temp.ske==1&true.ske==0)/sum(adj.temp.ske==1) ## FDR: 0.7055215
sum(adj.temp.ske==1&true.ske==1)/sum(true.ske==1) ## Power: 0.8807339
library(foreach)
library(doFuture)
boot.adj<- dagbagM::hc_boot_parallel(Y=Y.n, n.boot=50, nodeType=rep("c",p), whiteList=NULL, blackList=NULL, standardize=TRUE, tol = 1e-6, maxStep = 1000, restart=1, seed = 1,  nodeShuffle=TRUE, numThread = 2, verbose = FALSE)
#(iv) Evaluations
## results on DAG estimation
sum(adj.bag==1&true.dir==0)/sum(adj.bag==1) ## FDR:  0.3636364
#(iii) Bootstrap aggregation of DAGs learnt from bootstrap resamples: threshold=0 corresponds to 50% selection freq. cutoff
adj.bag=dagbagM::score_shd(boot.adj, alpha = 1, threshold=0)
#(iv) Evaluations
## results on DAG estimation
sum(adj.bag==1&true.dir==0)/sum(adj.bag==1) ## FDR:  0.3636364
sum(adj.bag==1&true.dir==1)/sum(true.dir==1) ## Power:  0.6422018
## results on skeleton graph estimation
adj.bag.ske=skeleton(adj.bag)
sum(adj.bag.ske==1&true.ske==0)/sum(adj.bag.ske==1) ## FDR: 0.1818182
sum(adj.bag.ske==1&true.ske==1)/sum(true.ske==1) ## Power: 0.8256881
## results on moral graph estimation
adj.bag.moral=moral_graph(adj.bag)
sum(adj.bag.moral==1&true.moral==0)/sum(adj.bag.moral==1) ## FDR: 0.2369942
sum(adj.bag.moral==1&true.moral==1)/sum(true.moral==1) ## Power:0.7173913
## results on vstructures estimation
adj.bag.vstr=vstructures(adj.bag)
vstr.corr=compare.vstructures(target.vstructures=adj.bag.vstr, true.vstructures=true.vstr)
1-nrow(vstr.corr)/nrow(adj.bag.vstr) ## FDR: 0.421875
nrow(vstr.corr)/nrow(true.vstr) ## Power: 0.4805195
remove.packages("InterCellDAGv3")
q()
setwd("~/Documents/GitHub/dagbagM/dagbagMv2")
library(devtools)
devtools::install()
library(dagbagMv2)
data(example)
Y.n      <- example$Y
p        <- ncol(Y.n)
true.dir <- example$true.dir
true.ske <- skeleton(true.dir)
nodeType <- rep("c", p)
N_BOOT   <- 50   # adjust as needed
SEED     <- 1
N_THREAD <- 5    # adjust to available cores
## ── hc_boot_parallel (original: full-data std, old seeding) ─────────────────
t1 <- proc.time()
freq.par <- hc_boot_parallel(
Y = Y.n, n.boot = N_BOOT, nodeType = nodeType,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = SEED, nodeShuffle = TRUE,
numThread = N_THREAD, output_type = "freq"
)
t1 <- (proc.time() - t1)[3]
## ── hc_boot current (per-sample std, upfront seeding) ───────────────────────
t2 <- proc.time()
freq.new <- hc_boot(
Y = Y.n, n.boot = N_BOOT, nodeType = nodeType,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = SEED, nodeShuffle = TRUE,
backend = "future", workers=N_THREAD,  output_type = "array"
)
t2 <- (proc.time() - t2)[3]
cat(sprintf("hc_boot_parallel : %.1fs\n", t1))
cat(sprintf("hc_boot          : %.1fs\n\n", t2))
## ── Frequency matrix comparison ──────────────────────────────────────────────
diff <- freq.new - freq.par
library(dagbagMv2)
data(example)
Y.n      <- example$Y
p        <- ncol(Y.n)
true.dir <- example$true.dir
true.ske <- skeleton(true.dir)
nodeType <- rep("c", p)
N_BOOT   <- 50   # adjust as needed
SEED     <- 1
N_THREAD <- 5    # adjust to available cores
## ── hc_boot_parallel (original: full-data std, old seeding) ─────────────────
t1 <- proc.time()
freq.par <- hc_boot_parallel(
Y = Y.n, n.boot = N_BOOT, nodeType = nodeType,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = SEED, nodeShuffle = TRUE,
numThread = N_THREAD, output_type = "freq"
)
t1 <- (proc.time() - t1)[3]
## ── hc_boot current (per-sample std, upfront seeding) ───────────────────────
t2 <- proc.time()
freq.new <- hc_boot(
Y = Y.n, n.boot = N_BOOT, nodeType = nodeType,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = SEED, nodeShuffle = TRUE,
backend = "future", workers=N_THREAD,  output_type = "array"
)
t2 <- (proc.time() - t2)[3]
cat(sprintf("hc_boot_parallel : %.1fs\n", t1))
cat(sprintf("hc_boot          : %.1fs\n\n", t2))
## ── Aggregated DAG comparison ────────────────────────────────────────────────
eval_dag <- function(adj) {
fdr   <- if (sum(adj) > 0) sum(adj == 1 & true.dir == 0) / sum(adj) else NA
power <- sum(adj == 1 & true.dir == 1) / sum(true.dir)
ske   <- skeleton(adj)
s_fdr   <- if (sum(ske) > 0) sum(ske == 1 & true.ske == 0) / sum(ske) else NA
s_power <- sum(ske == 1 & true.ske == 1) / sum(true.ske)
c(DAG_FDR = fdr, DAG_Power = power, SKE_FDR = s_fdr, SKE_Power = s_power)
}
adj.par <- score_shd_freq(freq.par, alpha = 1, freq.cutoff = 0.5)
adj.new <- score_shd(freq.new, alpha = 1, freq.cutoff = 0.5)
res <- rbind(
"hc_boot_parallel" = eval_dag(adj.par),
"hc_boot"          = eval_dag(adj.new)
)
cat("\n=== Aggregated DAG (freq.cutoff = 0.5) ===\n")
print(round(res, 7))
cat(sprintf("\nEdge counts: hc_boot_parallel=%d  hc_boot=%d\n",
sum(adj.par), sum(adj.new)))
cat(sprintf("Edges in common: %d\n", sum(adj.par == 1 & adj.new == 1)))
######## array vs. freq matching confirmation
rm(list=ls())
library(dagbagMv2)
data(example)
Y.n      <- example$Y
p        <- ncol(Y.n)
true.dir <- example$true.dir
true.ske <- skeleton(true.dir)
true.moral <- moral_graph(true.dir)
true.vstr  <- vstructures(true.dir)
# Path A: array output -> score_shd (C++ freq)
boot.adj <- dagbagMv2::hc_boot(Y = Y.n, n.boot = 50, nodeType = rep("c", p),
whiteList = NULL, blackList = NULL,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = 1, nodeShuffle = TRUE,
backend = "sequential", output_type = "array",
verbose = FALSE)
adj.A <- dagbagMv2::score_shd(boot.adj, alpha = 1, freq.cutoff = 0.5)
# Path B: freq output -> score_shd_freq (R freq)
freq.B <- dagbagMv2::hc_boot(Y = Y.n, n.boot = 50, nodeType = rep("c", p),
whiteList = NULL, blackList = NULL,
standardize = TRUE, tol = 1e-6, maxStep = 1000,
restart = 1, seed = 1, nodeShuffle = TRUE,
backend = "sequential", output_type = "freq",
verbose = FALSE)
adj.B <- dagbagMv2::score_shd_freq(freq.B, alpha = 1, freq.cutoff = 0.5)
cat("Paths identical:", identical(adj.A, adj.B), "\n")
cat("Max abs diff:   ", max(abs(adj.A - adj.B)), "\n\n")
cat("=== Results (path A = array -> score_shd) ===\n")
cat("DAG edges:", sum(adj.A), "\n")
cat("DAG FDR:  ", sum(adj.A==1 & true.dir==0) / sum(adj.A==1), "\n")
cat("DAG Power:", sum(adj.A==1 & true.dir==1) / sum(true.dir==1), "\n")
adj.A.ske <- skeleton(adj.A)
cat("SKE FDR:  ", sum(adj.A.ske==1 & true.ske==0) / sum(adj.A.ske==1), "\n")
cat("SKE Power:", sum(adj.A.ske==1 & true.ske==1) / sum(true.ske==1), "\n")
adj.A.moral <- moral_graph(adj.A)
cat("Moral FDR:", sum(adj.A.moral==1 & true.moral==0) / sum(adj.A.moral==1), "\n")
cat("Moral Pow:", sum(adj.A.moral==1 & true.moral==1) / sum(true.moral==1), "\n")
adj.A.vstr <- vstructures(adj.A)
vstr.corr  <- compare.vstructures(adj.A.vstr, true.vstr)
cat("Vstr FDR: ", 1 - nrow(vstr.corr) / nrow(adj.A.vstr), "\n")
cat("Vstr Pow: ", nrow(vstr.corr) / nrow(true.vstr), "\n")
remove.packages("dagbagMv2")
q()
